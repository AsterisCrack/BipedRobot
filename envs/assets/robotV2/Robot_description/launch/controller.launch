<launch>

<rosparam file="$(find Robotv2URDF_description)/launch/controller.yaml" command="load"/>
<node name="controller_spawner" pkg="controller_manager" type="spawner" respawn="false" output="screen" ns="Robotv2URDF" args="l_hip_roll_joint_position_controller r_hip_roll_joint_position_controller r_hip_pitch_joint_position_controller l_hip_pitch_joint_position_controller r_knee_joint_position_controller l_knee_joint_position_controller r_ankle_roll_joint_position_controller l_ankle_roll_joint_position_controller r_ankle_pitch_joint_position_controller l_ankle_pitch_joint_position_controller r_hip_yaw_position_controller l_hip_yaw_position_controller joint_state_controller "/>
<node name="robot_state_publisher" pkg="robot_state_publisher" type="robot_state_publisher" respawn="false" output="screen">
  <remap from="/joint_states" to="/Robotv2URDF/joint_states"/>
</node>

</launch>